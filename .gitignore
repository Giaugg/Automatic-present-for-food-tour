# ###########################################################
# GITIGNORE CHO DỰ ÁN MONOREPO (FE & BE)
# ###########################################################

# --- Dependencies ---
# Chặn node_modules ở cả thư mục gốc, front-end/ và back-end/
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js (Front-end) ---
.next/
out/
next-env.d.ts
*.tsbuildinfo

# --- Production & Build Output ---
build/
dist/
.vercel

# --- Environment Files (Bảo mật cực kỳ quan trọng) ---
# Không bao giờ push file .env chứa mật khẩu DB/API Key lên GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --- Backend & Server Misc ---
# Chặn các file ảnh/audio upload lên trong quá trình chạy local
back-end/node_modules/*
front-end/node_modules/*
!back-end/uploads/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Database (Nếu bạn có dùng SQLite hoặc xuất file SQL) ---
*.sqlite
*.db
back-end/backups/*.sql

# --- Testing ---
coverage/

# --- Misc / OS ---
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/