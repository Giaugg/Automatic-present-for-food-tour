# Local backend URL (dev)
NEXT_PUBLIC_API_URL=http://localhost:5000

# API source mode: auto | local | remote
# - auto: prefer NEXT_PUBLIC_API_URL, otherwise localhost in dev and same-origin in production/Vercel
# - local: always use http://localhost:5000
# - remote: fetch from NEXT_PUBLIC_API_DISCOVERY_URL
NEXT_PUBLIC_API_SOURCE=auto

# Optional discovery endpoint when NEXT_PUBLIC_API_SOURCE=remote
# NEXT_PUBLIC_API_DISCOVERY_URL=https://raw.githubusercontent.com/Giaugg/Automatic-present-for-food-tour/main/urls.json

# Vercel note:
# Set NEXT_PUBLIC_API_URL to your deployed backend domain, for example:
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com
