DATABASE_URL=postgres://postgres:password@localhost:5432/Automatic-present-for-food-tour

# --- Rate limit (đơn vị phút) ---
# Ví dụ: 2 phút cho tối đa 120 request
RATE_LIMIT_WINDOW_MINUTES=2
RATE_LIMIT_MAX=120

# Giới hạn riêng cho login/register
AUTH_RATE_LIMIT_WINDOW_MINUTES=10
AUTH_RATE_LIMIT_MAX=10

# --- Frontend URL cho redirect sau thanh toan ---
FRONTEND_URL=http://localhost:3000

# --- ZaloPay config ---
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_CREATE_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query
ZALOPAY_CALLBACK_URL=http://localhost:5000/api/payments/zalopay/callback